# Copy to .dev.vars for local wrangler dev. Do NOT commit .dev.vars.
# In production, set these via `wrangler secret put <NAME>`.

# 32 random bytes, base64. Used to hash IPs server-side before storage.
IP_HASH_SALT=

# 32 random bytes, base64. Used to HMAC the autonomous signature tokens.
SIGNATURE_TOKEN_HMAC=

# Empty in Level 1. In Level 2, set to the base64 of the 32-byte secret salt
# reconstituted from the 5 custodian shares.
# SECRET_SALT_B64=

# Fine-grained GitHub PAT scoped to the archives repo (Contents: Read & Write).
# ARCHIVE_GITHUB_TOKEN=
