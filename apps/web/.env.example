# Copy to .env.local for local dev, or set as build-time vars in Cloudflare Pages.
# All PUBLIC_ variables are exposed to the browser bundle — never put secrets here.

PUBLIC_API_BASE=https://api.noalacord.com
PUBLIC_POW_BITS=18

